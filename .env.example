# Local build config, sourced by build.sh. Copy to .env (gitignored), or to a per-host
# .env.<hostname> (preferred when the NFS repo dir is shared across build hosts on different
# subnets — build.sh checks .env.<hostname> first), and set PIP_OPTS to a PyPI cache so docker
# rebakes hit cached wheels. With neither, build.sh resolves from upstream PyPI (slower, still
# works). CI leaves PIP_OPTS empty (no LAN cache) and builds against upstream PyPI.
PIP_OPTS="--index-url http://192.168.5.1:5001/index/ --trusted-host 192.168.5.1"
